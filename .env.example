BWA_WEBAPP_IMAGE=ghcr.io/your-org/bwa-webapp:1.0.0
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=__GENERATE_APP_KEY__
DB_CONNECTION=pgsql
DB_HOST=database
DB_PORT=5432
DB_DATABASE=bwa_dojo
DB_USERNAME=postgres
DB_PASSWORD=postgres
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=__GENERATE_JWT_SECRET__
JWT_TTL_MINUTES=120
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
AUTO_MIGRATE=true
AUTO_SEED=false
WEBAPP_FRONTEND_PORT=3000
WEBAPP_BACKEND_PORT=8000
DATABASE_PORT=5432
